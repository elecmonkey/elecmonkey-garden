# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/.pnpm-store/
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# mermaid cache
/.mermaid-cache/

# cspell configuration
.cspell.json

git*.sh
git*.txt
# workspace packages
/packages/*/node_modules/
/packages/*/.next/
/packages/*/out/
/packages/*/dist/
/packages/*/.rsbuild/
/packages/*/build/

# rust
/target/

# generated native bindings
/packages/content-compiler-napi/*.node
/packages/content-compiler-napi/index.js
/packages/content-compiler-napi/native.d.ts
/packages/content-compiler-napi/npm/
/packages/content-compiler-napi/artifacts/
