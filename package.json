{
  "name": "elecmonkey-garden",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @elecmonkey/garden-site dev",
    "build": "pnpm --filter @elecmonkey/garden-site build",
    "start": "pnpm --filter @elecmonkey/garden-site start",
    "preview": "pnpm --filter @elecmonkey/garden-site preview",
    "lint": "rslint --type-check .",
    "pack:content-compiler": "pnpm --filter @elecmonkey/garden-content-compiler pack:all",
    "pack:content-compiler:linux-x64": "pnpm --filter @elecmonkey/garden-content-compiler pack:linux-x64",
    "pack:content-compiler:local": "pnpm --filter @elecmonkey/garden-content-compiler pack:local"
  },
  "devDependencies": {
    "@rslint/core": "^0.5.3"
  },
  "packageManager": "pnpm@10.33.0"
}
