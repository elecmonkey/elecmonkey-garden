{
  "name": "@elecmonkey/garden-site",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "rsbuild dev --environment web",
    "build": "rsbuild build && SSG_WORKERS=auto node .rsbuild/ssg/build.js",
    "start": "rsbuild preview --environment web",
    "preview": "rsbuild preview --environment web",
    "lint": "rslint --type-check .",
    "build:compiler": "pnpm --filter @elecmonkey/garden-content-compiler build",
    "build:with-compiler": "pnpm run build:compiler && pnpm run build"
  },
  "dependencies": {
    "@elecmonkey/garden-content-compiler": "0.2.3",
    "@viz-js/viz": "^3.28.0",
    "katex": "^0.17.0",
    "lucide-react": "^1.24.0",
    "mermaid": "^11.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0",
    "shiki": "^4.3.1"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.1.5",
    "@rsbuild/plugin-react": "^2.1.0",
    "@rsbuild/plugin-tailwindcss": "^2.0.3",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.2"
  },
  "type": "module"
}
