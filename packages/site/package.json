{
  "name": "@elecmonkey/garden-site",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "rsbuild dev --environment web",
    "build": "pnpm run build:compiler && rsbuild build && node .rsbuild/ssg/build.js",
    "start": "rsbuild preview --environment web",
    "preview": "rsbuild preview --environment web",
    "lint": "eslint .",
    "type-check": "tsc -b --noEmit",
    "build:compiler": "pnpm --filter @elecmonkey/garden-content-compiler build"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "katex": "^0.16.45",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router": "^7.15.1",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.3",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.0.2",
    "@elecmonkey/garden-content-compiler": "workspace:*"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.0.7",
    "@rsbuild/plugin-react": "^2.0.0",
    "@rsbuild/plugin-tailwindcss": "^2.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "eslint": "^9.39.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3"
  },
  "type": "module"
}
