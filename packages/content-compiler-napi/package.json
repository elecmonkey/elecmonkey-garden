{
  "name": "@elecmonkey/garden-content-compiler",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "index.cjs",
    "*.node"
  ],
  "scripts": {
    "build": "napi build --platform --release && rslib build",
    "build:debug": "napi build --platform && rslib build",
    "check": "cargo check -p garden_content_compiler_napi && rslib build"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "@rslib/core": "^0.21.5",
    "@typescript/native-preview": "7.0.0-dev.20260525.1"
  },
  "napi": {
    "binaryName": "garden-content-compiler",
    "packageName": "@elecmonkey/garden-content-compiler",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
