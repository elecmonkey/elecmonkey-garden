{
  "name": "@elecmonkey/garden-content-compiler",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "*.node"
  ],
  "scripts": {
    "build": "napi build --platform --release --no-js --dts native.d.ts && rslib build",
    "build:debug": "napi build --platform --no-js --dts native.d.ts && rslib build",
    "build:native": "napi build --platform --release --no-js --dts native.d.ts",
    "build:native:linux-x64-gnu": "napi build --platform --release --no-js --dts native.d.ts --target x86_64-unknown-linux-gnu --use-napi-cross",
    "build:native:linux-x64-musl": "napi build --platform --release --no-js --dts native.d.ts --target x86_64-unknown-linux-musl --cross-compile",
    "check": "cargo check -p garden_content_compiler_napi && rslib build",
    "pack:local": "node scripts/build-package.mjs --pack",
    "pack:linux-x64": "node scripts/build-package.mjs --target x86_64-unknown-linux-gnu --target x86_64-unknown-linux-musl --pack",
    "pack:all": "node scripts/build-package.mjs --all --platform-packages --pack",
    "pack:darwin-x64": "node scripts/build-package.mjs --target x86_64-apple-darwin --pack",
    "pack:darwin-arm64": "node scripts/build-package.mjs --target aarch64-apple-darwin --pack",
    "pack:linux-x64-gnu": "node scripts/build-package.mjs --target x86_64-unknown-linux-gnu --pack",
    "pack:linux-x64-musl": "node scripts/build-package.mjs --target x86_64-unknown-linux-musl --pack",
    "pack:linux-arm64": "node scripts/build-package.mjs --target aarch64-unknown-linux-gnu --target aarch64-unknown-linux-musl --pack",
    "pack:linux-arm64-gnu": "node scripts/build-package.mjs --target aarch64-unknown-linux-gnu --pack",
    "pack:linux-arm64-musl": "node scripts/build-package.mjs --target aarch64-unknown-linux-musl --pack",
    "pack:win32-x64": "node scripts/build-package.mjs --target x86_64-pc-windows-msvc --pack",
    "pack:win32-arm64": "node scripts/build-package.mjs --target aarch64-pc-windows-msvc --pack"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "@rslib/core": "^0.21.5",
    "@typescript/native-preview": "7.0.0-dev.20260525.1"
  },
  "napi": {
    "binaryName": "garden-content-compiler",
    "packageName": "@elecmonkey/garden-content-compiler",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
